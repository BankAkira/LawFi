# App
DEBUG=true

# Database (port 5433 to avoid conflicts with other projects)
DATABASE_URL=postgresql+asyncpg://lawfi:lawfi@localhost:5433/lawfi

# Auth
SECRET_KEY=change-me-to-a-random-secret-in-production

# Google OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rulings

# Anthropic (Claude) - for data extraction pipeline
ANTHROPIC_API_KEY=sk-ant-xxx

# Google Cloud - for OCR and embeddings
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=us-central1

# Cloudflare R2 - for PDF storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lawfi-pdfs
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# Vertex AI Embedding
EMBEDDING_MODEL=text-multilingual-embedding-002
EMBEDDING_DIMENSION=768
